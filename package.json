{
  "name": "flipbook-app",
  "private": true,
  "version": "0.1.0",
  "description": "Interactive CS-architecture flipbook canvas (Express + SSE + React)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "node server/src/index.js",
    "sync-prompts": "node scripts/sync-prompts.mjs",
    "test": "npm run test --workspaces --if-present",
    "clean:data": "rimraf server/data",
    "clean:dist": "rimraf web/dist",
    "clean": "rimraf server/data web/dist"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
